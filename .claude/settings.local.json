{
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npx next build:*)",
      "WebFetch(domain:docs.fystack.io)",
      "Bash(npx --yes svgo --multipass --pretty=false public/svg/wallet_as_service/exchange-otc.svg -o /tmp/img-opt/exchange-otc.svgo.svg)",
      "Bash(cp public/Fystack_logo.png /tmp/img-opt/Fystack_logo.png.bak)",
      "Bash(convert public/Fystack_logo.png -resize 256x256 -strip /tmp/img-opt/Fystack_logo_256.png)",
      "Bash(pngquant --quality=70-90 --force --output public/Fystack_logo.png /tmp/img-opt/Fystack_logo_256.png)",
      "Bash(cp public/Logo_fystack_light.png /tmp/img-opt/Logo_fystack_light.png.bak)",
      "Bash(convert public/Logo_fystack_light.png -resize 512x -strip /tmp/img-opt/Logo_fystack_light_512.png)"
    ]
  }
}
